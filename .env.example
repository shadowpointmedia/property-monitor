# Google Sheets service account credentials
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Google Sheet ID (from the URL: /spreadsheets/d/<SHEET_ID>/edit)
GOOGLE_SHEET_ID=

# Apify API token (set automatically by Railway Apify integration, or add manually)
APIFY_TOKEN=

# Zenfolio account password (used by zenfolio-import.js backfill script)
ZENFOLIO_PASSWORD=

# Optional: set to "true" to trigger an immediate run on startup (useful for testing)
RUN_NOW=
